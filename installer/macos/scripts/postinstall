#!/bin/bash
set -euo pipefail

BASE_DIR="/Library/Application Support/eGuard"
LOG_DIR="${BASE_DIR}/logs"
QUARANTINE_DIR="${BASE_DIR}/quarantine"
PLIST_PATH="/Library/LaunchDaemons/com.eguard.agent.plist"

# Create directories
mkdir -p "$LOG_DIR"
mkdir -p "$QUARANTINE_DIR"

# Restrict permissions on eGuard runtime directories
chown -R root:wheel "$BASE_DIR"
chmod 700 "$BASE_DIR"
chmod 700 "$LOG_DIR"
chmod 700 "$QUARANTINE_DIR"

# Set binary/plist permissions
chmod 755 /usr/local/bin/eguard-agent
chown root:wheel "$PLIST_PATH"
chmod 644 "$PLIST_PATH"

# Do not start LaunchDaemon during package installation. The DMG-based
# configurator or install.sh flow writes runtime config and then bootstraps
# the service explicitly after enrollment settings are in place.

# --- Full Disk Access (FDA) notice ---
cat <<'FDA_NOTICE'

================================================================================
  eGuard Agent — Full Disk Access (FDA) Required
================================================================================

  The eGuard agent uses macOS Endpoint Security (eslogger) for file, network,
  and process telemetry. This requires Full Disk Access permission.

  OPTION 1 — Manual grant (standalone machines):
    System Settings > Privacy & Security > Full Disk Access
    Click "+", navigate to /usr/local/bin/eguard-agent, and enable it.

  OPTION 2 — MDM TCC profile (enterprise deployment):
    Deploy a Privacy Preferences Policy Control profile granting
    SystemPolicyAllFiles to /usr/local/bin/eguard-agent
    (bundle identifier: com.eguard.agent, code requirement: identifier "eguard-agent").

  WITHOUT FDA:
    The agent runs in degraded mode — process events only (via polling).
    File and network telemetry will NOT be collected.

================================================================================
FDA_NOTICE

exit 0
